# Clawith Environment Variables
# Copy this file to .env and fill in the values

# Security
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# Database (auto-configured by setup.sh; override for custom setups)
# For local dev, ssl=disable is required to prevent asyncpg SSL negotiation hang
# DATABASE_URL=postgresql+asyncpg://clawith:clawith@localhost:5432/clawith?ssl=disable

# Redis
# REDIS_URL=redis://localhost:6379/0

# Feishu OAuth (optional, for SSO login)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:3000/auth/feishu/callback

# Agent workspace data directory.
# Default: local host -> ~/.clawith/data/agents ; container runtime -> /data/agents
# AGENT_DATA_DIR=

# Cloud Storage Backend (default: local)
# STORAGE_BACKEND=local         # "local" (filesystem) or "s3" (S3-compatible object storage)
# STORAGE_BUCKET=               # Bucket name for S3/OBS
# STORAGE_ENDPOINT_URL=         # Custom endpoint for S3-compatible providers (e.g., https://obs.cn-north-4.myhuaweicloud.com for Huawei OBS)
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_CACHE_DIR=/tmp/clawith_cache  # Local cache directory; empty string disables caching
# STORAGE_CACHE_TTL_SECONDS=60

# Jina AI API key (for jina_search and jina_read tools — get one at https://jina.ai)
# Without a key, the tools still work but with lower rate limits
JINA_API_KEY=

# Public app URL used in user-facing links, such as password reset emails.
# Optional — auto-detected in the following order:
#   1. This environment variable (set it for manual override)
#   2. Replit domain (REPL_SLUG + REPL_OWNER) when running on Replit
#   3. Cached URL from a previous web request (for background tasks)
#   4. X-Forwarded-Host / X-Forwarded-Proto headers from reverse proxies
#   5. Fallback: https://try.clawith.ai
# For production multi-instance deployments, set this explicitly.
PUBLIC_BASE_URL=

# Google Workspace CLI integration (optional)
# OAuth callback path — defaults to /api/gws/auth/callback
# GWS_OAUTH_CALLBACK_PATH=/api/gws/auth/callback
# Override the OAuth redirect URI (optional, for local development only).
# Set this to http://localhost:8008/api/gws/auth/callback when using a
# "Desktop app" type OAuth client in Google Cloud Console for local testing.
# Production deployments should leave this empty (auto-generated from PUBLIC_BASE_URL).
# GWS_OAUTH_REDIRECT_URI=

# Lark CLI integration (optional)
# OAuth callback path — defaults to /api/lark/auth/callback
# LARK_OAUTH_CALLBACK_PATH=/api/lark/auth/callback
# Override the OAuth redirect URI (optional).
# LARK_OAUTH_REDIRECT_URI=


# Password reset token lifetime in minutes
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
